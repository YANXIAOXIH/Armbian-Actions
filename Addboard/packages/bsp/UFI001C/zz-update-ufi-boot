#!/bin/bash
# /etc/kernel/postinst.d/zz-update-ufi-boot
set -e

# Capture version and optional manual DTB path
KERNEL_VERSION="$1"
MANUAL_DTB="$2"
[[ -z "${KERNEL_VERSION}" ]] && exit 0

echo "--- [UFI Boot Updater] Building boot image for kernel ${KERNEL_VERSION} ---"

# --- 0. Environment and Dependency Check ---
if [ ! -x "/usr/bin/mkbootimg" ]; then
    echo "Fatal Error: mkbootimg not found! Do not reboot."
    exit 1
fi

ENV_FILE="/boot/armbianEnv.txt"

# --- 1. Identify current hardware model ---
RUNNING_MODEL=$(cat /sys/firmware/devicetree/base/model 2>/dev/null | tr -d '\0')
echo "Detected hardware: ${RUNNING_MODEL:-Unknown}"

# --- 2. Auto-detection logic ---
if [[ "${RUNNING_MODEL,,}" == *"ufi001c"* ]]; then
    BOARD="ufi001c"
elif [[ "${RUNNING_MODEL,,}" == *"ufi003"* ]]; then
    BOARD="ufi003"
elif [[ "${RUNNING_MODEL,,}" == *"uz801"* ]]; then
    BOARD="uz801"
else
    BOARD="ufi001c"
    echo "Warning: Model unrecognized, defaulting to ufi001c"
fi

if [[ "${RUNNING_MODEL,,}" == *"pro"* ]]; then
    VARIANT="-pro"
else
    VARIANT=""
fi

# Determine default DTB based on hardware
if [[ "$BOARD" == "uz801" ]] && [[ -z "$VARIANT" ]]; then
    AUTO_DTB="qcom/msm8916-yiming-uz801v3.dtb"
else
    AUTO_DTB="qcom/msm8916-thwc-${BOARD}${VARIANT}.dtb"
fi

# --- 3. Determine target DTB ---
if [ -f "$ENV_FILE" ]; then source "$ENV_FILE"; fi

# Priority: 1. Command Line Argument -> 2. armbianEnv.txt -> 3. Auto-detection
if [ -n "$MANUAL_DTB" ]; then
    TARGET_DTB="$MANUAL_DTB"
    echo "Using manually specified DTB: $TARGET_DTB"
    # Update armbianEnv.txt for persistence
    if grep -q "^fdtfile=" "$ENV_FILE"; then
        sed -i "s|^fdtfile=.*|fdtfile=${TARGET_DTB}|" "$ENV_FILE"
    else
        echo "fdtfile=${TARGET_DTB}" >> "$ENV_FILE"
    fi
elif [ -n "$fdtfile" ] && [ -f "/usr/lib/linux-image-${KERNEL_VERSION}/${fdtfile}" ]; then
    TARGET_DTB="$fdtfile"
    echo "Using user-defined DTB (armbianEnv.txt): $TARGET_DTB"
else
    TARGET_DTB="$AUTO_DTB"
    echo "Using auto-detected DTB: $TARGET_DTB"
    if [ -f "$ENV_FILE" ]; then
        if grep -q "^fdtfile=" "$ENV_FILE"; then
            sed -i "s|^fdtfile=.*|fdtfile=${TARGET_DTB}|" "$ENV_FILE"
        else
            echo "fdtfile=${TARGET_DTB}" >> "$ENV_FILE"
        fi
    fi
fi

# --- 4. Extract Boot Parameters ---
CURRENT_ROOT=$(cat /proc/cmdline | sed -n 's/.*root=\([^ ]*\).*/\1/p')
if [ -z "$CURRENT_ROOT" ]; then
    echo "Fatal Error: Failed to extract root parameter from /proc/cmdline"
    exit 1
fi
CMDLINE="${BOOTIMG_CMDLINE_EXTRA} root=${CURRENT_ROOT} ${extraargs}"

# --- 5. Prepare files and package ---
WORK_DIR=$(mktemp -d)
trap 'rm -rf -- "$WORK_DIR"' EXIT

REAL_KERNEL=$(ls /boot/vmlinu*-${KERNEL_VERSION} | head -n 1)
INITRD_FILE="/boot/initrd.img-${KERNEL_VERSION}"
DTB_PATH="/usr/lib/linux-image-${KERNEL_VERSION}/${TARGET_DTB}"

# Validation
[ ! -f "$DTB_PATH" ] && { echo "Fatal Error: DTB file not found: $DTB_PATH"; exit 1; }
[ ! -f "$INITRD_FILE" ] && { echo "Fatal Error: initramfs missing: $INITRD_FILE"; exit 1; }

# Compress kernel if needed
if gzip -t "$REAL_KERNEL" 2>/dev/null; then
    echo "Kernel is already compressed, skipping re-compression."
    cp "$REAL_KERNEL" "${WORK_DIR}/Image.gz"
else
    echo "Compressing kernel..."
    gzip -9 -c "$REAL_KERNEL" > "${WORK_DIR}/Image.gz"
fi

cat "${WORK_DIR}/Image.gz" "${DTB_PATH}" > "${WORK_DIR}/kernel-dtb"

echo "Generating boot.img..."
/usr/bin/mkbootimg \
    --base 0x80000000 \
    --kernel_offset 0x00080000 \
    --ramdisk_offset 0x04000000 \
    --tags_offset 0x03500000 \
    --pagesize 2048 \
    --second_offset 0x00f00000 \
    --ramdisk "${INITRD_FILE}" \
    --cmdline "${CMDLINE}" \
    --kernel "${WORK_DIR}/kernel-dtb" \
    -o "${WORK_DIR}/boot.img"

# --- 6. Flash to boot partition ---
BOOT_PART="/dev/disk/by-partlabel/boot"
if [ ! -b "$BOOT_PART" ]; then
    echo "Fatal Error: Boot partition not found!"
    exit 1
fi

echo "Flashing boot partition..."
dd if="${WORK_DIR}/boot.img" of="$BOOT_PART" bs=4M status=none
sync

echo "--- [Success] Boot image updated successfully! ---"
exit 0