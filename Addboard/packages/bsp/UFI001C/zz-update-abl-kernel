#!/bin/bash
# /etc/kernel/postinst.d/zz-update-ufi-boot
#
# Description: Post-install hook for kernel updates on Qualcomm UFI devices.
# Auto-detects the board model, appends the correct DTB to the kernel, 
# generates a boot.img, and flashes it directly to the boot partition.
#
# Exit immediately if a command exits with a non-zero status
set -e

# --- 1. Argument Parsing (Compatible with APT hooks and manual execution) ---
ARG1="$1"
ARG2="$2"

if [[ -z "$ARG1" ]]; then
    # No arguments provided, default to the currently running kernel
    KERNEL_VERSION=$(uname -r)
    MANUAL_DTB=""
elif [[ "$ARG1" == *.dtb ]]; then
    # Allow manual execution like: ./script msm8916-xxx.dtb
    KERNEL_VERSION=$(uname -r)
    MANUAL_DTB="$ARG1"
else
    # APT upgrade passes: ARG1=kernel_version, ARG2=/boot/vmlinuz-kernel_version
    KERNEL_VERSION="$ARG1"
    if [[ "$ARG2" == /boot/vmlinu* || -z "$ARG2" ]]; then
        MANUAL_DTB=""
    else
        MANUAL_DTB="$ARG2"
    fi
fi

# Format the manually specified DTB (ensure it has the 'qcom/' prefix)
if [[ -n "$MANUAL_DTB" && "$MANUAL_DTB" != qcom/* && "$MANUAL_DTB" != /* ]]; then
    MANUAL_DTB="qcom/$MANUAL_DTB"
fi

echo "[INFO] UFI Boot Updater - Target Kernel: ${KERNEL_VERSION}"

# --- 2. Environment & Dependency Check ---
if [ ! -x "/usr/local/bin/mkbootimg" ]; then
    echo "[INFO] Downloading a compatible version of mkbootimg..."
    mkdir -p /usr/local/bin
    wget -q -O /usr/local/bin/mkbootimg https://launchpadlibrarian.net/810765814/mkbootimg
    chmod +x /usr/local/bin/mkbootimg
fi

ENV_FILE="/boot/armbianEnv.txt"
if [ -f "$ENV_FILE" ]; then
    unset fdtfile extraargs rootdev BOOTIMG_CMDLINE_EXTRA
    source "$ENV_FILE"
fi

# --- 3. Auto-detect Hardware Model ---
RUNNING_MODEL=$(cat /sys/firmware/devicetree/base/model 2>/dev/null | tr -d '\0')
echo "[INFO] Detected hardware: ${RUNNING_MODEL:-Unknown}"

BOARD=""
VARIANT=""
if [[ "${RUNNING_MODEL,,}" == *"ufi001c"* ]]; then
    BOARD="ufi001c"
elif [[ "${RUNNING_MODEL,,}" == *"ufi003"* ]]; then
    BOARD="ufi003"
elif [[ "${RUNNING_MODEL,,}" == *"uz801"* ]]; then
    BOARD="uz801"
fi
[[ "${RUNNING_MODEL,,}" == *"pro"* ]] && VARIANT="-pro"

# Determine the auto-detected DTB
AUTO_DTB=""
if [ -n "$BOARD" ]; then
    if [[ "$BOARD" == "uz801" && -z "$VARIANT" ]]; then
        AUTO_DTB="qcom/msm8916-yiming-uz801v3.dtb"
    else
        AUTO_DTB="qcom/msm8916-thwc-${BOARD}${VARIANT}.dtb"
    fi
fi

# --- 4. Core Logic: Determine Target DTB (Strict Priority) ---
# Priority 1: Manually specified (MANUAL_DTB)
# Priority 2: Auto-detected from hardware (AUTO_DTB)
# Priority 3: Read from config file (fdtfile)
# Priority 4: Hardcoded fallback value (FALLBACK_DTB)
FALLBACK_DTB="qcom/msm8916-thwc-ufi001c.dtb"

if [ -n "$MANUAL_DTB" ]; then
    TARGET_DTB="$MANUAL_DTB"
    echo "[INFO] Priority 1 - Using manually specified DTB: $TARGET_DTB"
elif [ -n "$AUTO_DTB" ]; then
    TARGET_DTB="$AUTO_DTB"
    echo "[INFO] Priority 2 - Using auto-detected hardware DTB: $TARGET_DTB"
elif [ -n "$fdtfile" ]; then
    TARGET_DTB="$fdtfile"
    echo "[INFO] Priority 3 - Hardware unknown, using armbianEnv.txt fallback: $TARGET_DTB"
else
    TARGET_DTB="$FALLBACK_DTB"
    echo "[WARN] Priority 4 - Nothing matched, defaulting to: $TARGET_DTB"
fi

# Persist the selected DTB to armbianEnv.txt
if [ -f "$ENV_FILE" ]; then
    if grep -q "^fdtfile=" "$ENV_FILE"; then
        if [ "$fdtfile" != "$TARGET_DTB" ]; then
            sed -i "s|^fdtfile=.*|fdtfile=${TARGET_DTB}|" "$ENV_FILE"
            echo "[INFO] Auto-corrected fdtfile in $ENV_FILE to $TARGET_DTB"
        fi
    else
        echo "fdtfile=${TARGET_DTB}" >> "$ENV_FILE"
        echo "[INFO] Added fdtfile=${TARGET_DTB} to $ENV_FILE"
    fi
fi

# --- 5. Extract Boot Arguments (CMDLINE) ---
CURRENT_ROOT=$(cat /proc/cmdline | sed -n 's/.*root=\([^ ]*\).*/\1/p')
if [ -z "$CURRENT_ROOT" ]; then
    echo "[ERROR] Failed to extract root parameter from /proc/cmdline"
    exit 1
fi
RAW_CMDLINE="${BOOTIMG_CMDLINE_EXTRA} root=${CURRENT_ROOT} ${extraargs}"
# Trim extra spaces
CMDLINE=$(echo "$RAW_CMDLINE" | xargs)

# --- 6. Prepare Files and Generate boot.img ---
WORK_DIR=$(mktemp -d)
trap 'rm -rf -- "$WORK_DIR"' EXIT

REAL_KERNEL=$(ls /boot/vmlinu*-${KERNEL_VERSION} 2>/dev/null | head -n 1)
INITRD_FILE="/boot/initrd.img-${KERNEL_VERSION}"
DTB_PATH="/usr/lib/linux-image-${KERNEL_VERSION}/${TARGET_DTB}"

# Verify file integrity
[ ! -f "$REAL_KERNEL" ] && { echo "[ERROR] Kernel file not found: $REAL_KERNEL"; exit 1; }
[ ! -f "$INITRD_FILE" ] && { echo "[ERROR] initramfs missing: $INITRD_FILE (Wait for initramfs hooks to finish?)"; exit 1; }

if [ ! -f "$DTB_PATH" ]; then
    echo "[WARN] DTB file not found at $DTB_PATH, checking alternative path..."
    DTB_PATH_ALT="/usr/lib/linux-image-${KERNEL_VERSION}/${TARGET_DTB#qcom/}"
    if [ -f "$DTB_PATH_ALT" ]; then
        DTB_PATH="$DTB_PATH_ALT"
    else
        echo "[ERROR] DTB file not found in library!"
        exit 1
    fi
fi

# Check if kernel is already compressed, compress if not (avoids huge Image files)
if gzip -t "$REAL_KERNEL" 2>/dev/null; then
    echo "[INFO] Kernel is already compressed, copying..."
    cp "$REAL_KERNEL" "${WORK_DIR}/Image.gz"
else
    echo "[INFO] Compressing raw kernel..."
    gzip -9 -c "$REAL_KERNEL" > "${WORK_DIR}/Image.gz"
fi

# Core step: Append DTB to the end of the kernel
echo "[INFO] Appending DTB to kernel..."
cat "${WORK_DIR}/Image.gz" "${DTB_PATH}" > "${WORK_DIR}/kernel-dtb"

echo "[INFO] Generating boot.img..."
/usr/local/bin/mkbootimg \
    --base 0x80000000 \
    --kernel_offset 0x00080000 \
    --ramdisk_offset 0x04000000 \
    --tags_offset 0x03500000 \
    --pagesize 2048 \
    --second_offset 0x00f00000 \
    --ramdisk "${INITRD_FILE}" \
    --cmdline "${CMDLINE}" \
    --kernel "${WORK_DIR}/kernel-dtb" \
    -o "${WORK_DIR}/boot.img"

# --- 7. Flash to Boot Partition ---
BOOT_PART="/dev/disk/by-partlabel/boot"
if [ ! -b "$BOOT_PART" ]; then
    echo "[ERROR] Boot partition not found at $BOOT_PART !"
    exit 1
fi

echo "[INFO] Flashing image to $BOOT_PART ..."
dd if="${WORK_DIR}/boot.img" of="$BOOT_PART" bs=4M status=none
sync

echo "[SUCCESS] Boot image updated for ${KERNEL_VERSION} using ${TARGET_DTB}"
exit 0